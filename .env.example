# Required: LAN IP this host serves on. Used for the self-signed cert SAN
# and the mDNS A-record so https://<LAN_IP>:8443/ works on every device.
LAN_IP=192.168.16.10

# Optional: hostname to publish via mDNS. With a working host avahi-daemon,
# https://reflektor.local:8443/ works on the LAN without remembering the IP.
# Set MDNS_HOSTNAME= (empty) to disable.
MDNS_HOSTNAME=reflektor.local

# Optional: HTTP Basic-auth PIN. Any username, this value as password.
# Leave empty for no auth. The /ca.crt and /healthz endpoints stay open.
PIN=

# Optional: allow multiple simultaneous receivers (TV + tablet + laptop).
# Default off — one receiver at a time, like the original behavior.
MULTI_RECEIVER=0
